{
  "capabilities": {
    "http-mocks": "verified",
    "interactions-click": "verified",
    "interactions-touch-gestures": "manual",
    "layout-web": "verified",
    "native-clipboard": "stubbed",
    "native-geolocation": "stubbed",
    "native-haptics": "stubbed",
    "native-network": "stubbed",
    "native-storage": "stubbed",
    "real-device": "manual",
    "routing": "verified"
  },
  "commands": {
    "dev": "vite",
    "seedAdapter": "npx tsx .codeyam/seed-adapter.ts",
    "test": "npx vitest run"
  },
  "components": {
    "fileExtensions": [
      ".tsx",
      ".jsx"
    ],
    "primitives": [
      "div",
      "span",
      "h1",
      "h2",
      "h3",
      "p",
      "img",
      "ul",
      "li",
      "a",
      "button",
      "input",
      "form"
    ]
  },
  "data": {
    "importStatement": "window.localStorage",
    "seedAdapterType": "localStorage",
    "type": "local-storage"
  },
  "defaultScreenSize": "iPhone 16",
  "id": "capacitor-vite-react",
  "name": "Capacitor + Vite + React",
  "preview": {
    "defaultPort": 5173,
    "kind": "iframe"
  },
  "routing": {
    "componentManifest": ".codeyam/generated/components.ts",
    "isolationEntry": ".codeyam/harness/isolate.tsx",
    "type": "query-param"
  },
  "screenSizes": {
    "iPad": {
      "height": 1180,
      "width": 820
    },
    "iPhone 16": {
      "height": 852,
      "width": 393
    },
    "iPhone 16 Pro Max": {
      "height": 932,
      "width": 430
    }
  },
  "styling": {
    "tokenFile": "src/index.css",
    "type": "css-custom-properties"
  }
}