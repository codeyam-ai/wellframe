// Prisma 7 with SQLite via better-sqlite3 driver adapter.
//
// IMPORTANT: Use "prisma-client-js" (NOT "prisma-client").
// The "prisma-client" generator requires a custom output path which
// breaks Turbopack import resolution and seed script imports.
// "prisma-client-js" outputs to node_modules/@prisma/client which
// works everywhere with standard imports.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ──────────────────────────────────────────────
// Wellframe — Dashboard "Daily Briefing Console"
//
// Three flat tables. Each scenario wipes + reseeds a single day's worth of
// data; production starts empty (day-one onboarding state). The dashboard
// reads the single most-recent DailyBriefing plus its Vitals and Workout.
// ──────────────────────────────────────────────

// The core "today" record driving the console. Most fields are nullable so
// the empty / partial states render gracefully.
model DailyBriefing {
  id               Int      @id @default(autoincrement())
  date             String   // ISO date of the reading, e.g. "2026-07-06"
  dateLabel        String   // metabar stamp, e.g. "06 Jul · 07:02"
  readinessScore   Int?     // 0-100 readiness dial value; null = no reading yet
  readinessLabel   String?  // "Primed" | "Steady" | "Compromised"
  readinessDelta   Int?     // points vs the 7-day average (may be negative)
  headline         String?  // serif verdict, e.g. "You're cleared for a quality day."
  statusLine       String?  // e.g. "PRIMED · +4 VS 7-DAY AVERAGE"
  elevation        String?  // coordinates strip, e.g. "1,240 FT"
  wind             String?  // e.g. "4 KT"
  windowLabel      String?  // training window, e.g. "07–10"
  suggestedWorkout String?  // primary CTA label, e.g. "Execute Zone 2 · 45 min"
  coachMessage     String?  // coach transmission blockquote
  coachDirective   String?  // e.g. "Zone 2 · 45 min / ~4.5 mi / 64% of plan"
  coachSignature   String?  // e.g. "local model · 07:02 · 0 cloud calls"
}

// One overnight telemetry row (HRV, Resting HR, Sleep, Steps, ...). Flat, so
// the partial-data scenario simply seeds fewer rows.
model Vital {
  id       Int      @id @default(autoincrement())
  order    Int      @default(0)  // display order in the telemetry stack
  label    String   // e.g. "HRV", "Resting HR", "Sleep", "Steps"
  value    String   // formatted value, e.g. "68", "7:24", "8,240"
  unit     String?  // e.g. "ms", "bpm"
  delta    String?  // trend chip, e.g. "▲6"
  trackPct Int      @default(0)      // 0-100 fill for the track bar
  positive Boolean  @default(false)  // mint track (good) vs signal-blue track
}

// A logged activity. On the Dashboard it feeds the Field Log (yesterday's
// activity, read latest-by-id); on the Activity Timeline it is one dated entry
// among many. Absent (zero rows) in the no-workout scenarios. The timeline
// fields (occurredAt / duration / kind) are nullable so the existing dashboard
// seeds — which omit them — stay valid.
model Workout {
  id         Int     @id @default(autoincrement())
  title      String  // e.g. "Ridgeline Trail Run"
  typeLabel  String? // photo caption, e.g. "▸ Ridgeline Trail · Z2"
  photoUrl   String? // documentary photo (forced grayscale in the UI)
  distance   String? // e.g. "8.2 mi"
  pace       String? // e.g. "8:42"
  vertical   String? // e.g. "1,240 ft"
  duration   String? // e.g. "1:12:40"
  occurredAt String? // ISO datetime for timeline placement, e.g. "2026-07-06T07:14:00Z"
  kind       String? // "run" | "ride" | "strength" | "walk" | "yoga" — drives the timeline chips
}

// A daily check-in shown on the Activity Timeline: a subjective snapshot logged
// morning or evening. Absent (zero rows) in scenarios without check-ins.
model Mood {
  id           Int     @id @default(autoincrement())
  occurredAt   String  // ISO datetime
  partOfDay    String  // "morning" | "evening"
  energy       Int?    // 1-5 self-rating
  mood         String? // short word, e.g. "Steady"
  sleepQuality Int?    // 1-5
  soreness     Int?    // 1-5
  stress       Int?    // 1-5
  note         String? // optional free-text reflection
}

// A body-weight reading shown on the Activity Timeline.
model Weight {
  id         Int     @id @default(autoincrement())
  occurredAt String  // ISO datetime
  value      String  // formatted value, e.g. "154.2"
  unit       String  @default("lb")
  delta      String? // trend chip, e.g. "▼0.4"
  positive   Boolean @default(false) // mint (good) vs signal-blue track
}

// ──────────────────────────────────────────────
// Trends — one chart per (metric × range). Each TrendMetric row is a single
// chart: its label/unit/summary plus an ordered set of TrendPoints. The Trends
// page loads every metric and the range switcher (Weekly / Monthly / Yearly)
// re-scopes which metrics render. Production starts empty → the page shows the
// day-one "no history yet" state.
// NOTE: models here are intentionally FLAT — a child carries its parent's id as
// a plain Int column with NO Prisma `@relation`, matching the rest of this
// schema. This keeps scenario seeding order-independent: with no FK constraint
// the seed adapter can insert child rows before parent rows. The loaders stitch
// children onto parents in JS (a `where: { metricId: { in } }` query), so
// `include` is not needed.
model TrendMetric {
  id        Int     @id @default(autoincrement())
  order     Int     @default(0) // display order within a range
  metricKey String  // stable key, e.g. "sleep" | "hrv" | "rhr" | "mileage"
  label     String  // "Sleep", "HRV", "Resting HR", "Mileage"
  unit      String? // "hrs", "ms", "bpm", "mi"
  range     String  // "weekly" | "monthly" | "yearly"
  latest    String  // formatted latest value, e.g. "7:18"
  delta     String? // trend chip, e.g. "▲ 0.4"
  positive  Boolean @default(false) // mint (improving) vs signal-blue
  summary   String? // one-line read, e.g. "Trending up 4 of 6 weeks"
}

// One dated sample within a TrendMetric chart. Flat + ordered so a sparse
// scenario simply seeds fewer points. `metricId` is a plain column (no FK).
model TrendPoint {
  id          Int    @id @default(autoincrement())
  metricId    Int    // parent TrendMetric.id (plain column, no FK constraint)
  order       Int    @default(0) // left-to-right position
  bucketLabel String // x-axis label, e.g. "Mon", "Wk 3", "Mar"
  value       Float  // numeric value used to plot the line
}

// ──────────────────────────────────────────────
// Recovery Center — the single "recovery read" (like DailyBriefing), combining
// sleep / HRV / RHR / load / stress / fatigue into one score, plus contributing
// factors and suggested actions. Production starts empty → day-one empty state.
// Flat like the rest of this schema — RecoveryFactor / RecoveryAction carry a
// plain `recoveryId` column (no FK constraint), so scenario seeding is
// order-independent and the loader stitches children in JS.
model RecoveryRead {
  id         Int     @id @default(autoincrement())
  date       String  // ISO date of the read
  dateLabel  String  // metabar stamp, e.g. "07 Jul · 07:04"
  score      Int?    // 0-100 recovery score; null = no read yet
  label      String? // "Recovering" | "Ready" | "Strained"
  headline   String? // serif verdict, e.g. "Your system is still catching up."
  statusLine String? // e.g. "RECOVERING · -6 VS 7-DAY AVERAGE"
  summary    String? // longer read shown under the score
}

// One contributing signal in the recovery read (Sleep, HRV, RHR, Load, Stress,
// Fatigue). Drillable: `detail` is revealed when the factor is expanded.
// `recoveryId` is a plain column (no FK constraint).
model RecoveryFactor {
  id         Int     @id @default(autoincrement())
  recoveryId Int     // parent RecoveryRead.id (plain column, no FK constraint)
  order      Int     @default(0)
  label      String  // "Sleep", "HRV", "Resting HR", "Training Load", "Stress"
  value      String  // formatted value, e.g. "6:41", "54 ms"
  state      String  // "strong" | "steady" | "strained"
  trackPct   Int     @default(0) // 0-100 fill for the track bar
  positive   Boolean @default(false)
  detail     String? // plain-language read revealed on expand
}

// One suggested recovery action (recovery run, rest day, mobility, hydration).
// Expandable: `detail` is revealed when the action is opened. `recoveryId` is a
// plain column (no FK constraint).
model RecoveryAction {
  id            Int     @id @default(autoincrement())
  recoveryId    Int     // parent RecoveryRead.id (plain column, no FK constraint)
  order         Int     @default(0)
  title         String  // "Easy recovery run", "Full rest day"
  kind          String  // "run" | "rest" | "mobility" | "hydration" | "walk" | "nutrition"
  durationLabel String? // "30-40 min", "All day"
  detail        String? // why this is suggested, revealed on expand
}

// ──────────────────────────────────────────────
// Goals — a tracked objective with a numeric target and current progress.
// Production starts empty → day-one "set your first goal" empty state. Creating
// a goal (the page's primary interaction) writes a row here.
model Goal {
  id        Int     @id @default(autoincrement())
  order     Int     @default(0)
  title     String  // "Run 500 miles this year"
  category  String  // "distance" | "race" | "sleep" | "strength" | "habit" | "recovery"
  metric    String  // what's measured, e.g. "Miles", "Nights ≥ 8h", "Sessions"
  target    Float   // target value
  current   Float   @default(0) // progress toward target
  unit      String? // "mi", "nights", "sessions"
  cadence   String? // "This year", "This month", "Weekly"
  dueLabel  String? // "Dec 31", "6 weeks left"
  note      String? // optional context
  createdAt String  // ISO timestamp
}

// A persisted connection to an AI coach or health-data provider. Production
// starts with ZERO rows (day-one: every provider shows "Connect"). Connecting a
// provider writes a row here; the Connections panel and dashboard read these
// rows to show real connected / synced / active state instead of hardcoded demo
// statuses. The catalog of *available* providers stays static in
// components/dashboard/connections.ts — this table records only what's connected.
model ProviderConnection {
  id            Int     @id @default(autoincrement())
  providerId    String  @unique // one connection row per provider; "claude" | "gemini" | "openai" | "ollama" | "lmstudio" | "mcp-local" | "apple" | "garmin" | "oura" | "whoop"
  kind          String  // "ai" | "health"
  method        String  // "oauth" | "apiKey" | "localEndpoint" | "mcp"
  status        String  // "connected" | "synced" | "error"
  detail        String? // status line: "Local · 0 cloud calls", "Synced 07:02", "key ••••4f2a", or an error message
  endpoint      String? // for localEndpoint / mcp methods
  isActiveCoach Boolean @default(false) // only one AI connection is active at a time
  connectedAt   String  // ISO timestamp, e.g. "2026-07-06T07:02:00Z"
}
