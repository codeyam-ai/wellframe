{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true
  },
  // Tests run through the repo's vitest (which compiles TS itself) and import
  // `vitest`, which is not a dependency of this package — so they are excluded
  // from the server build rather than emitted into dist/.
  "include": ["src"],
  "exclude": ["src/**/*.test.ts"]
}
