{
  "name": "wellframe-coach-mcp",
  "version": "0.1.1",
  "description": "MCP server exposing the Wellframe coach's tools over the user's local health database",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "test": "cd .. && npx vitest run mcp-server/src",
    "pack": "bash scripts/pack.sh",
    "sign": "bash scripts/sign.sh",
    "smoke": "node scripts/smoke.mjs",
    "verify-signature": "node scripts/verify-signature.mjs",
    "bundle": "npm run pack && npm run smoke && npm run sign",
    "validate": "npx @anthropic-ai/mcpb validate manifest.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "sql.js": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "@types/node": "^20",
    "@types/sql.js": "^1.4.11",
    "typescript": "^5.7.0"
  }
}
